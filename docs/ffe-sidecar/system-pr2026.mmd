---
title: "FFE sidecar forwarders — libdatadog PR #2026"
---
flowchart TD
    subgraph TracerProc["PHP tracer process (or other libdatadog consumer)"]
        ExposurePayload["EVP exposure batch<br/>(JSON envelope, encoded by tracer)"]
        MetricPayload["OTLP/protobuf metrics batch<br/>(encoded by tracer)"]
        FfiExposures["ddog_sidecar_send_ffe_exposures FFI<br/>(payload only)"]
        FfiMetrics["ddog_sidecar_send_ffe_metrics FFI<br/>(endpoint + payload)"]
    end

    subgraph IPC["IPC transport (tarpc over Unix socket)"]
        EnqueueActions["SidecarAction::FfeExposures(payload)<br/>SidecarAction::FfeMetrics { endpoint, payload }"]
    end

    subgraph SidecarProc["libdatadog sidecar process (Rust, async)"]
        EnqueueHandler["enqueue_actions handler<br/>(sidecar_server.rs)"]
        Filter["FFE actions filtered out before<br/>applications.entry(queue_id) gate<br/>(session-scoped, no per-app metadata needed) — THIS PR"]
        ExposureFlusher["ffe_exposures_flusher::send_payload<br/>(Endpoint = session.trace_config.endpoint<br/>with path swapped to /evp_proxy/v2/api/v2/exposures)"]
        MetricsFlusher["ffe_metrics_flusher::send_payload<br/>(Endpoint = caller-supplied OTLP HTTP URL)"]
        HttpClient["NativeCapabilities HTTP client"]
    end

    subgraph Backend["Backend"]
        AgentEVP["Datadog Agent<br/>/evp_proxy/v2/api/v2/exposures<br/>(X-Datadog-EVP-Subdomain: event-platform-intake)"]
        OtlpIntake["OTLP HTTP intake<br/>(POST /v1/metrics, application/x-protobuf)"]
    end

    ExposurePayload --> FfiExposures
    MetricPayload --> FfiMetrics
    FfiExposures -- "tarpc enqueue_actions" --> EnqueueActions
    FfiMetrics -- "tarpc enqueue_actions" --> EnqueueActions
    EnqueueActions --> EnqueueHandler
    EnqueueHandler --> Filter
    Filter -- "FfeExposures" --> ExposureFlusher
    Filter -- "FfeMetrics" --> MetricsFlusher
    ExposureFlusher --> HttpClient
    MetricsFlusher --> HttpClient
    HttpClient -- "POST" --> AgentEVP
    HttpClient -- "POST" --> OtlpIntake

    classDef thisPR fill:#ddd6fe,stroke:#6d28d9,color:#1e1b4b,stroke-width:3px
    classDef consumer fill:#bbf7d0,stroke:#16a34a,color:#052e16
    classDef backend fill:#fde68a,stroke:#b45309,color:#3f1f00

    class FfiExposures,FfiMetrics,EnqueueActions,EnqueueHandler,Filter,ExposureFlusher,MetricsFlusher,HttpClient thisPR
    class ExposurePayload,MetricPayload consumer
    class AgentEVP,OtlpIntake backend
